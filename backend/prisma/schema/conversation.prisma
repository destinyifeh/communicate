model Conversation {
  id                 String              @id @default(uuid())
  channel            ConversationChannel
  status             ConversationStatus  @default(BOT_HANDLED)
  subject            String?
  lastMessagePreview String?
  lastMessageAt      DateTime?
  unreadCount        Int                 @default(0)
  starred            Boolean             @default(false)
  detectedIntent     String?
  intentMetadata     Json?
  assignedAgentId    String?
  assignedAt         DateTime?
  escalatedAt        DateTime?
  escalationReason   String?
  contactId          String
  businessId         String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assignedAgent      User?               @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  business           Business            @relation(fields: [businessId], references: [id])
  contact            Contact             @relation(fields: [contactId], references: [id])
  inquiries          Inquiry[]
  messages           Message[]

  @@map("conversations")
}

model Message {
  id                    String           @id @default(uuid())
  body                  String
  direction             MessageDirection
  sender                MessageSender
  status                MessageStatus    @default(SENT)
  twilioMessageSid      String?
  twilioFrom            String?
  twilioTo              String?
  emailMessageId        String?
  emailSubject          String?
  emailFrom             String?
  emailTo               String?
  emailCc               String?
  emailBcc              String?
  emailReplyToMessageId String?
  emailHtml             String?
  mediaUrls             Json?
  agentId               String?
  conversationId        String
  createdAt             DateTime         @default(now())
  agent                 User?            @relation("AgentMessages", fields: [agentId], references: [id])
  conversation          Conversation     @relation(fields: [conversationId], references: [id])

  @@map("messages")
}
